---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { newsItems, mediaCoverage } from '@/data/news'
---

<BaseLayout title="News & Outreach">
  <article class="max-w-4xl mx-auto px-4 py-8 sm:py-12 space-y-10">
    <!-- Media Coverage Section -->
    <section
      class="bg-white dark:bg-zinc-800/60 border border-gray-200 dark:border-zinc-600 shadow-md dark:shadow-md p-6 rounded-md backdrop-blur-sm"
    >
      <h2 class="text-xl font-semibold text-indigo-700 dark:text-indigo-400 mb-4">Media Coverage & Outreach</h2>
      <ul class="space-y-3">
        {
          mediaCoverage.map(({ text, link }) => (
            <li class="text-sm">
              {link ? (
                <a href={link} target="_blank" rel="noopener noreferrer" class="text-indigo-600 hover:underline">
                  {text}
                </a>
              ) : (
                <span class="text-gray-800 dark:text-gray-200">{text}</span>
              )}
            </li>
          ))
        }
      </ul>
    </section>

    <!-- News Section -->
    <section>
      <h2 class="text-xl font-semibold text-indigo-700 dark:text-indigo-400 mb-4">Lab News</h2>
      <div class="space-y-6">
        {
          newsItems.map(({ date, description }) => (
            <div class="bg-white dark:bg-zinc-800/60 border border-gray-200 dark:border-zinc-600 shadow-md dark:shadow-md p-6 rounded-md transition-shadow duration-300 backdrop-blur-sm">
              <p class="text-sm text-indigo-600 font-medium mb-1">{date}</p>
              <p class="text-gray-800 dark:text-gray-200 text-sm">{description}</p>
            </div>
          ))
        }
      </div>
    </section>
  </article>
</BaseLayout>
