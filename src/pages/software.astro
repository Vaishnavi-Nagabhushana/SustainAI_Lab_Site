---
import BaseLayout from '../layouts/BaseLayout.astro'
import publicationsData from '../data/Ayon_borthakur.json'
---

<BaseLayout title="Software & Patents • SustainAI Lab">
  <article class="max-w-4xl mx-auto px-4 py-6 sm:py-12">
    <section class="mb-10">
      <h1 class="text-2xl font-semibold text-indigo-700 dark:text-indigo-400 mb-4">
        Sapicore: A PyTorch-based Framework for Neuromorphic Modeling
      </h1>

      <div
        class="bg-white dark:bg-zinc-800/60 border border-gray-200 dark:border-zinc-600 p-6 rounded-md shadow-md dark:shadow-md backdrop-blur-sm hover:shadow-lg transition-shadow duration-300"
      >
        <p class="text-gray-900 dark:text-gray-100 font-semibold mb-2">Author:</p>
        <p class="text-gray-900 dark:text-gray-300 mb-4">Matthew Einhorn, Ayon Borthakur, Thomas Cleland</p>

        <p class="text-gray-800 dark:text-gray-200 leading-relaxed mb-6">
          Sapicore was developed as a project of the Computational Physiology Laboratory at Cornell University. It is a
          framework that provides high-level abstractions to help write neuromorphic models using PyTorch. Sapicore
          itself does not contain any concrete models; instead, each model may have its own repository that implements
          the Sapicore components used by the model.
        </p>

        <a
          href="https://cplab.github.io/sapicore/index.html"
          target="_blank"
          rel="noopener noreferrer"
          class="text-indigo-600 dark:text-indigo-400 hover:underline font-semibold transition-colors duration-300"
        >
          Official Sapicore Website
        </a>
      </div>
    </section>

    <section class="mt-12">
      <h2 class="text-xl font-semibold text-indigo-700 dark:text-indigo-400 mb-6">Patents</h2>
      {
        [...new Set(publicationsData.filter((pub) => pub.type === 'Patent').map((pub) => pub.year))]
          .sort((a, b) => b - a)
          .map((year) => (
            <div key={year} class="mb-8">
              <h3 class="text-lg font-semibold text-indigo-600 dark:text-indigo-300 mb-4">{year}</h3>
              <ul class="list-none pl-0 space-y-6">
                {publicationsData
                  .filter((pub) => pub.year === year && pub.type === 'Patent')
                  .map((patent) => (
                    <li
                      key={patent.title}
                      class="bg-white dark:bg-zinc-800/60 border border-gray-200 dark:border-zinc-600 p-4 rounded-md shadow-sm hover:shadow-md backdrop-blur-sm transition"
                    >
                      <p>
                        <b class="text-gray-900 dark:text-gray-100">
                          <a
                            href={patent.citation_url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-indigo-600 dark:text-indigo-400 hover:underline"
                          >
                            {patent.title}
                          </a>
                        </b>
                        <br />
                        <span class="italic text-gray-600 dark:text-gray-300">{patent.authors.join(', ')}</span>
                        <br />
                        <span class="text-gray-700 dark:text-gray-400">{patent.source}</span>
                        <br />
                        {patent.cites_url && (
                          <a
                            href={patent.cites_url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-sm text-indigo-500 dark:text-indigo-300 hover:underline"
                          >
                            Citations
                          </a>
                        )}
                      </p>
                    </li>
                  ))}
              </ul>
            </div>
          ))
      }
    </section>
  </article>
</BaseLayout>
